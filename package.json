{
  "name": "terminal-workspace-for-agent",
  "version": "0.1.2",
  "description": "terminal-workspace-for-agent (twa) — terminal workspace for AI agents. Command: twa. Package: terminal-workspace-for-agent.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanggggjie/terminal-workspace-for-agent.git"
  },
  "homepage": "https://github.com/yanggggjie/terminal-workspace-for-agent#readme",
  "bugs": {
    "url": "https://github.com/yanggggjie/terminal-workspace-for-agent/issues"
  },
  "keywords": [
    "tui",
    "pty",
    "terminal",
    "workspace",
    "automation",
    "agent",
    "cli",
    "xterm"
  ],
  "bin": {
    "twa": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/copy-watch-vendor.js && rm -rf dist && tsc && cp -r src/watch-ui dist/watch-ui && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node scripts/verify.js",
    "prepack": "npm run build",
    "version": "node scripts/sync-skill-version.js",
    "prepublishOnly": "npm test",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^15.0.0",
    "fastify": "^5.8.5",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0 <27.0.0"
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
